#######
# EW FIRE LASER ENTITIES
#######

entity = {
	name = "ew_fire_laser_small_muzzle_entity"
	pdxmesh = "locator_mesh"
	default_state = "idle"
	state = { name = "idle" state_time = 1 looping = no
		event = { time = 0 particle = "ew_fire_small_muzzle_particle" keep_particle = yes sound = { soundeffect = laser_fire } }
		event = { trigger_once = yes sound = { soundeffect = "distance_laser_fire" } }
	}
}

entity = {
	name = "ew_fire_laser_small_hit_entity"
	cull_radius = 1.0
	default_state = "idle"
	state = { name = "idle"
		start_event = { particle = ew_fire_small_hit_effect sound = { soundeffect = laser_hit } }
		start_event = { trigger_once = yes sound = { soundeffect = "distance_laser_hit" } }
	}
	state = { name = "stop" state_time = 0.5 looping = no }
}

